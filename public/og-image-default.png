<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <!-- Fond OpenGraph avec dégradé subtil -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f7f7f5;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect x="0" y="0" width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Logo Le Labo AI centré à gauche -->
  <g transform="translate(200, 315) scale(4)">
    <!-- Central hexagon -->
    <polygon points="0,-28 24,-14 24,14 0,28 -24,14 -24,-14" 
             fill="none" stroke="#9cf" stroke-width="2.2" stroke-linejoin="round"/>
    <!-- Nodes at vertices -->
    <circle cx="0" cy="-28" r="3" fill="#9cf"/>
    <circle cx="24" cy="-14" r="3" fill="#9cf"/>
    <circle cx="24" cy="14" r="3" fill="#9cf"/>
    <circle cx="0" cy="28" r="3" fill="#9cf"/>
    <circle cx="-24" cy="14" r="3" fill="#9cf"/>
    <circle cx="-24" cy="-14" r="3" fill="#9cf"/>
    <!-- Center dot -->
    <circle cx="0" cy="0" r="4" fill="#9cf" opacity="0.6"/>
    <!-- Internal connections -->
    <line x1="0" y1="0" x2="0" y2="-28" stroke="#9cf" stroke-width="0.8" opacity="0.35"/>
    <line x1="0" y1="0" x2="24" y2="14" stroke="#9cf" stroke-width="0.8" opacity="0.35"/>
    <line x1="0" y1="0" x2="-24" y2="14" stroke="#9cf" stroke-width="0.8" opacity="0.35"/>
  </g>
  
  <!-- Texte Le Labo AI -->
  <text x="400" y="280" font-family="Inter, Arial, sans-serif" font-size="72" font-weight="300" fill="#1a1a1a">
    <tspan fill="#9cf" font-weight="500">le</tspan><tspan fill="#1a1a1a" font-weight="300">labo</tspan><tspan fill="#9cf" font-weight="300">.ai</tspan>
  </text>
  
  <!-- Tagline -->
  <text x="400" y="340" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="400" fill="#4a4a4a">
    L'intelligence artificielle, décryptée en français
  </text>
  
  <!-- Niveaux -->
  <g transform="translate(400, 400)">
    <text x="0" y="0" font-family="Inter, Arial, sans-serif" font-size="20" font-weight="500" fill="#34c759">🌱 Débutant</text>
    <text x="150" y="0" font-family="Inter, Arial, sans-serif" font-size="20" font-weight="500" fill="#99ccff">🔧 Amateur</text>
    <text x="280" y="0" font-family="Inter, Arial, sans-serif" font-size="20" font-weight="500" fill="#e53e3e">⚡ Confirmé</text>
  </g>
</svg>