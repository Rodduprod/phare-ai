<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <g transform="translate(16, 16) scale(0.5)">
    <!-- Central hexagon -->
    <polygon points="0,-28 24,-14 24,14 0,28 -24,14 -24,-14" 
             fill="none" stroke="#9cf" stroke-width="4" stroke-linejoin="round"/>
    <!-- Nodes at vertices -->
    <circle cx="0" cy="-28" r="4" fill="#9cf"/>
    <circle cx="24" cy="-14" r="4" fill="#9cf"/>
    <circle cx="24" cy="14" r="4" fill="#9cf"/>
    <circle cx="0" cy="28" r="4" fill="#9cf"/>
    <circle cx="-24" cy="14" r="4" fill="#9cf"/>
    <circle cx="-24" cy="-14" r="4" fill="#9cf"/>
    <!-- Center dot -->
    <circle cx="0" cy="0" r="5" fill="#9cf" opacity="0.6"/>
    <!-- Internal connections -->
    <line x1="0" y1="0" x2="0" y2="-28" stroke="#9cf" stroke-width="1.5" opacity="0.4"/>
    <line x1="0" y1="0" x2="24" y2="14" stroke="#9cf" stroke-width="1.5" opacity="0.4"/>
    <line x1="0" y1="0" x2="-24" y2="14" stroke="#9cf" stroke-width="1.5" opacity="0.4"/>
  </g>
</svg>